# Public URL of the deployed Render backend. Do not include a trailing slash.
# Leave unset for local development when using the Vite proxy.
VITE_API_URL=https://ai-interview-preparation-platform-dh6d.onrender.com/api

# Google OAuth web client ID (optional; required only for Google Sign-In).
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
