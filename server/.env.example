# Render provides PORT automatically. Set this only for local development.
PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority

# Use a long, random value in production.
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Comma-separated URLs allowed to call the API. Include your deployed frontend.
CLIENT_URL=http://localhost:5173,https://your-frontend-domain.com
